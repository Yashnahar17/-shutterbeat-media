{
  "name": "shutterbeat-media",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "audit": "npm audit --audit-level=high",
    "build": "npm run seo:generate && vite build && vite build --ssr src/entry-server.jsx --outDir dist/server && npm run prerender",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "prerender": "node scripts/prerender.mjs",
    "seo:generate": "node scripts/generate-seo-assets.mjs",
    "security:check": "npm run lint && npm run audit && npm run build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "framer-motion": "^12.35.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-lazy-load-image-component": "^1.6.3",
    "react-router-dom": "^7.13.1",
    "swiper": "^12.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1"
  }
}
